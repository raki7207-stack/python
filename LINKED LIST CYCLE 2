class node:
    def __init__ (self,data):
        self.data=data
        self.next=None
class LinkedList:
    def __init__ (self):
        self.head=None
    def insert(self,data):
        nn=node(data)
        if self.head==None:
            self.head=nn
        else:
            temp=self.head
            while(temp.next!=None):
                temp=temp.next
            temp.next=nn
    def display(self):
        temp=self.head
        while(temp!=None):
            print(temp.data,end=">>")
            temp=temp.next


