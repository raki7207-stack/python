a = [[" " for _ in range(11)] for _ in range(10)]

for i in range(10):
    for j in range(11):
        if j == 0 or j == 10:          # outer vertical lines
            a[i][j] = "*"
        
        if i == j and i <= 5:          # left diagonal
            a[i][j] = "*"
        
        if i + j == 10 and i <= 5:     # right diagonal
            a[i][j] = "*"

for i in range(10):
    for j in range(11):
        print(a[i][j], end=" ")
    print()
