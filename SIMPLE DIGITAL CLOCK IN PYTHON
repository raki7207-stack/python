import time
import sys

h = int(input("Enter the hour: "))
m = int(input("Enter the minutes: "))
s = int(input("Enter the seconds: "))

while True:
    # Print clock in HH:MM:SS format
    sys.stdout.write(f"\r{h:02d}:{m:02d}:{s:02d}")
    sys.stdout.flush()

    time.sleep(1)

    s += 1

    if s == 60:
        s = 0
        m += 1

    if m == 60:
        m = 0
        h += 1

    if h == 24:
        h = 0
