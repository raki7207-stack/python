class rect:
    def __init__(self):
        self.l = int(input("Enter the length: "))
        self.b = int(input("Enter the Breadth: "))

    def display(self):
        return self.l * self.b

n = int(input("Enter the no.of rectangles: "))
l = []

for i in range(n):
    r = rect()
    l.append(r)

for i in l:
    print("area:", i.display())
