uppercase = 0
lowercase = 0
while True:
    char = input("Enter a character: ")
    if char.lower() in "aeiou" and len(char) == 1:
        print("Vowel entered. Stopping.")
        break
    if char.isupper():
        uppercase += 1
    elif char.islower():
        lowercase += 1
print(f"Total uppercase letters: {uppercase}")
print(f"Total lowercase letters: {lowercase}")
